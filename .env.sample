# Azure AI Foundry / Azure OpenAI v1 endpoint
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/openai/v1/
AZURE_OPENAI_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_API_KEY=<optional-if-using-api-key>
USE_MANAGED_IDENTITY=false

# BU mapping: Entra security group object ID to BU chargeback code
BU_GROUP_MAP_JSON={"11111111-1111-1111-1111-111111111111":"BU-FINANCE","22222222-2222-2222-2222-222222222222":"BU-HR"}
DEFAULT_BU_CODE=BU-UNKNOWN

# PoC storage. In production, forward this to Log Analytics/App Insights/Event Hub/Storage Table.
USAGE_LOG_PATH=usage_events.jsonl
